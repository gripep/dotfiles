# bat
# Source: https://github.com/sharkdp/bat

# Set the default theme for bat
# you can list all available themes with the command:
#   bat --list-themes
# or use themes compatible with sublime text (.tmTheme files)
export BAT_THEME="gruvbox-dark"

# Claude Code

# Enable fullscreen rendering, reducing flicker and keeping memory flat in long conversations
export CLAUDE_CODE_NO_FLICKER=1

# Use gpt models with Claude Code
# export ANTHROPIC_BASE_URL=
# export ANTHROPIC_AUTH_TOKEN=
# # Must be empty
# export ANTHROPIC_API_KEY=

# Codex

# export OPENAI_API_KEY=

# Docker

# Enable Docker CLI completions
fpath=($HOME/.docker/completions $fpath)
autoload -Uz compinit
compinit

# Homebrew

# Add Homebrew to PATH
eval "$(/opt/homebrew/bin/brew shellenv)"
