#!/usr/bin/env bash

# Create a directory if it doesn't exist
mk() {
    mkdir -p "$@"
}

# Create a directory if it doesn't exist and cd into it
mkcd() {
    mk "$@" && cd "$@"
}

# Load a .env file into the environment
loadenv() {
    env_file="${1:-.env}"

    if [[ ! -f "$env_file" ]]; then
        echo "Error: File '$env_file' not found."
        return 1
    fi

    set -a
    source "$env_file"
    set +a
}

# Delete all branches except main or the specified branch
git-branch-cleanup() {
    local keep_branch="${1:-main}"
    local branches
    branches=$(git branch --format='%(refname:short)' | grep -vx "$keep_branch")

    if [ -z "$branches" ]; then
        echo "No branches to delete."
        return 0
    fi

    echo "The following branches will be deleted:"
    echo "$branches"
    printf "Continue? [y/N] "
    read -r reply
    case "$reply" in
        y | Y) ;;
        *) echo "Aborted." && return 1 ;;
    esac

    # -d refuses to delete branches with unmerged work
    echo "$branches" | xargs -n1 git branch -d
}
