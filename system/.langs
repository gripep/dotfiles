# Languages and tools environment variables for Zsh

###############################################################################
# Flutter (+ Dart)                                                            #
###############################################################################

export PATH="$PATH:$HOME/Developer/opt/flutter/bin"

# flutterfire CLI
export PATH="$PATH:$HOME/.pub-cache/bin"

###############################################################################
# Go                                                                          #
###############################################################################

export GOPATH="$HOME/Developer/opt/go"
export PATH="$PATH:/usr/local/go/bin:$GOPATH/bin"

###############################################################################
# Python                                                                      #
###############################################################################

# pyenv
export PYENV_ROOT="$HOME/.pyenv" # Path to pyenv root
export PATH="$PYENV_ROOT/shims:$PATH" # Path to pyenv shims
eval "$(pyenv init - -zsh)" # Initialize pyenv

# poetry

# Minimum age of a package release in days before it is considered during dependency resolution.
# Safeguard against supply chain attacks.
# https://python-poetry.org/docs/configuration#solvermin-release-age
export POETRY_SOLVER_MIN_RELEASE_AGE=7

###############################################################################
# Ruby                                                                        #
###############################################################################

# Use Homebrew-installed Ruby instead of the system Ruby
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
export PATH="/opt/homebrew/lib/ruby/gems/4.0.0/bin:$PATH"

###############################################################################
# Rust                                                                        #
###############################################################################

export PATH="$HOME/.cargo/bin:$PATH"

###############################################################################
# JavaScript                                                                  #
###############################################################################

# Node.js & NVM
export NVM_DIR="$HOME/.nvm"
[ -s "/opt/homebrew/opt/nvm/nvm.sh" ] && \. "/opt/homebrew/opt/nvm/nvm.sh"  # This loads nvm
[ -s "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm" ] && \. "/opt/homebrew/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion
